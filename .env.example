# Copy trading bot configuration
# Copy this file to .env and fill in your values

# Hard cap per copied trade in USDC (default: 10.0)
TRADE_CAP_USDC=10.0

# How often to poll for new trades in seconds (default: 30)
POLL_INTERVAL_SECONDS=30

# Path to bullpen binary inside WSL
BULLPEN_BIN=/home/david/.bullpen/bin/bullpen

# Path to persist seen trade hashes (prevents duplicate copies on restart)
SEEN_TRADES_FILE=/home/david/.bullpen/seen_trades.json
